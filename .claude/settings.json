{
  "permissions": {
    "allow": [
      "Bash(source venv/bin/activate)",
      "Bash(ruff check .)",
      "Bash(ruff check --fix .)",
      "Bash(python manage.py check)",
      "Bash(python manage.py runserver)",
      "Bash(python manage.py migrate)",
      "Bash(python manage.py test)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(gh auth status)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(secret_key.txt)",
      "Read(**/settings/local.py)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; case \"$f\" in *.py) venv/bin/ruff check \"$f\" --fix;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
